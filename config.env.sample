# ============================================
# CIMF 管理系统配置文件模板
# ============================================

# ----- Django 核心设置 -----
# 【重要】Django 密钥：生产环境必须使用强随机密钥（50+字符）
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(50))"
# 开发环境可使用默认值，生产环境必须通过此变量设置
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式：开发环境=True，生产环境=False
DJANGO_DEBUG=True

# 环境标识：development（开发）或 production（生产）
# 生产环境会自动启用所有安全配置
DJANGO_ENV=development

# 允许访问的主机列表（逗号分隔）
# 生产环境示例: yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ----- IP 访问限制 -----
# 是否启用IP限制: true/false
IP_RESTRICTION_ENABLED=false
# 白名单IP列表，以英文逗号分隔，支持CIDR格式
# 示例: 127.0.0.1,192.168.1.0/24,10.0.0.1
IP_WHITELIST=127.0.0.1

# ----- HTTPS/SSL 安全配置（生产环境）-----
# HSTS (HTTP Strict Transport Security) 过期时间（秒）
# 0=禁用, 31536000=1年, 63072000=2年
# 生产环境建议: 31536000（1年）
DJANGO_HSTS_SECONDS=0

# HSTS 是否包含子域名: true/false
DJANGO_HSTS_INCLUDE_SUBDOMAINS=false

# HSTS 是否启用预加载: true/false
# 启用后可在 https://hstspreload.org/ 提交域名
DJANGO_HSTS_PRELOAD=false

# 是否强制 HTTP 重定向到 HTTPS: true/false
# 生产环境必须为 true
DJANGO_SSL_REDIRECT=false

# ----- Cookie 安全配置（生产环境）-----
# Session Cookie 是否仅通过 HTTPS 传输: true/false
# 生产环境必须为 true，防止 Cookie 被窃听
DJANGO_SESSION_COOKIE_SECURE=false

# CSRF Cookie 是否仅通过 HTTPS 传输: true/false
# 生产环境必须为 true
DJANGO_CSRF_COOKIE_SECURE=false

# ----- 数据库配置 -----
# 选择数据库类型: sqlite 或 mysql
DB_TYPE=sqlite
# 使用 MySQL 时，取消注释下方配置
# DB_TYPE=mysql
# DB_NAME=cimf
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
