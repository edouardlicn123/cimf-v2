# ============================================
# CIMF 管理系统配置文件模板
# ============================================

# ----- Django 设置 -----
SECRET_KEY=your-secret-key-here
DEBUG=True

# ----- 数据库配置 -----
# 选择数据库类型: sqlite 或 mysql
# 使用 SQLite（默认）
DB_TYPE=sqlite
# 使用 MySQL 时，取消注释下方配置
# DB_TYPE=mysql
# DB_NAME=cimf
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306