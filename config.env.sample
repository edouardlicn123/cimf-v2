# ============================================
# CIMF 管理系统配置文件模板
# ============================================

# ----- Django 设置 -----
SECRET_KEY=your-secret-key-here
DEBUG=True

# ----- IP 访问限制 -----
# 是否启用IP限制: true/false
IP_RESTRICTION_ENABLED=false
# 白名单IP列表，以英文逗号分隔，支持CIDR格式
# 示例: 127.0.0.1,192.168.1.0/24,10.0.0.1
IP_WHITELIST=127.0.0.1

# ----- 数据库配置 -----
# 选择数据库类型: sqlite 或 mysql
# 使用 SQLite（默认）
DB_TYPE=sqlite
# 使用 MySQL 时，取消注释下方配置
# DB_TYPE=mysql
# DB_NAME=cimf
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306