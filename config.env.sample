# =============================================
# 项目基础配置
# =============================================

# 项目名称（用于页面标题、邮件通知等）
PROJECT_NAME=FFE 项目跟进系统

# 运行模式：development / testing / production
FLASK_ENV=development

# =============================================
# Flask 服务配置
# =============================================

# Debug 模式：true / false
FLASK_DEBUG=true

# 服务监听地址：0.0.0.0=允许外部访问，127.0.0.1=仅本地
FLASK_HOST=0.0.0.0

# 服务监听端口
FLASK_PORT=5001

# =============================================
# 安全配置
# =============================================

# 应用密钥（生产环境必须设置，至少48字符）
# SECRET_KEY=

# 数据库连接（默认 SQLite）
# DATABASE_URL=sqlite:///instance/site.db
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# =============================================
# 文件上传配置
# =============================================

# 上传文件存储目录（相对于项目根目录）
# UPLOAD_FOLDER=persistent_uploads

# 单个文件最大大小（MB）
# MAX_CONTENT_LENGTH=16

# 允许的文件扩展名（逗号分隔）
# ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,gif,xlsx,docx,csv

# =============================================
# 会话与认证配置
# =============================================

# 会话 Cookie 名称
# SESSION_COOKIE_NAME=ffe_session

# 会话有效期（天）
# PERMANENT_SESSION_LIFETIME=14

# 登录失败锁定次数
# LOGIN_MAX_FAILURES=5

# 登录锁定时间（分钟）
# LOGIN_LOCK_MINUTES=30

# =============================================
# 业务功能开关
# =============================================

# 维护模式：true / false（开启后仅管理员可访问）
# MAINTENANCE_MODE=false

# 允许用户注册：true / false
# ALLOW_REGISTRATION=false

# =============================================
# 邮件配置（未来扩展）
# =============================================

# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_USE_TLS=true
# MAIL_DEFAULT_SENDER=noreply@example.com

# =============================================
# 云存储配置（未来扩展）
# =============================================

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# =============================================
# 缓存配置（未来扩展）
# =============================================

# CACHE_TYPE=simple
# REDIS_URL=redis://localhost:6379/0

# =============================================
# 日志配置（未来扩展）
# =============================================

# LOG_LEVEL=INFO
# LOG_RETENTION_DAYS=90
# ENABLE_AUDIT_LOG=true
